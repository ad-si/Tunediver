.claude/
.DS_Store
target/

# SQLite metadata/cover cache (and WAL sidecars). The deployed instance keeps
# this under ~/Library/Application Support/Tunediver; dev runs (make start /
# start-with-path) write it into server/ via ROCKET_CACHE_DB_PATH so they don't
# share the deployed instance's playlists. This pattern matches it anywhere.
tunediver-cache.db
tunediver-cache.db-wal
tunediver-cache.db-shm
